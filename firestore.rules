rules_version = '2';

// ============================================================================
// BookTutor — Firestore Security Rules
//
// All app data lives under users/{uid}/... (see userCol() in app.js — books,
// bookChapters, chat, notes, languages, langCards, langLessons all hang off
// the signed-in user's document). Sensitive settings (API key, model choice)
// never touch Firestore — they stay in local IndexedDB on the device.
//
// These rules replace the temporary "Test Mode" rules, which allowed anyone on
// the internet to read and write every user's data and were set to expire —
// after which ALL requests would have been denied and the app would break.
//
// The rule below: a signed-in user may read and write ONLY documents under
// their own users/{uid} subtree. Everyone else — including unauthenticated
// clients and other signed-in users — is denied. Anything not matched here is
// denied by default.
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // A user owns everything under their own users/{userId} path.
    match /users/{userId}/{documents=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // Everything else is denied by default (no catch-all allow).
  }
}
